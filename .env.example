# ANH-here Environment Configuration
# Copy this file to .env (for Docker deploy) or .env.local (for local dev) and fill in your values.
# DO NOT commit real secrets.

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database host
# - local app without Docker DB: localhost
# - app inside Docker: db
DB_HOST=localhost

# Database port (default MySQL port is 3306)
DB_PORT=3306

# Database name used by the application
DB_NAME=ANH-here_prod

# Database username used by the application
DB_USER=anh_user

# Database password used by the application
DB_PASSWORD=replace_with_db_password

# MySQL root password (used by docker-compose db service)
MYSQL_ROOT_PASSWORD=replace_with_root_password

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT secret key for signing tokens
# Generate a secure random string (min 32 characters recommended)
# Example: openssl rand -base64 32
JWT_KEY=your-super-secret-jwt-key-change-this-in-production

# Password hashing pepper
# Additional security layer for password hashing
# Example: openssl rand -hex 16
PEPPER=your_password_pepper_here

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API base URL (used in Swagger documentation and client-side config)
# For development: http://localhost:3000
# For production: https://your-domain.com
API_URL=http://localhost:3000

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================

# Node environment (development, production, test)
NODE_ENV=development

# ============================================================================
# ADDITIONAL CONFIGURATION
# ============================================================================

# You can add more environment variables here as needed
# Examples:
# LOG_LEVEL=debug
# EMAIL_SERVICE=smtp
# EMAIL_FROM=noreply@company.com
